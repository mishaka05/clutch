rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the authenticated user is the owner of the specified user data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. DEFAULT SAFETY NET
    // Deny read/write access to all other paths by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. USER ROOT DOCUMENT AND SUBCOLLECTIONS
    // Only the authenticated user whose Firebase UID matches the {userId} can read or write
    // to their profile document or any nested documents.
    match /users/{userId} {
      // Allows user to read and write their own profile document
      allow read, write: if isOwner(userId);
      
      // Allows user to read and write their own tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if isOwner(userId);
      }
      
      // Allows user to read and write their own logs (including focus sessions, calendar logs, and diagnostics)
      match /logs/{logId} {
        allow read, write: if isOwner(userId);
      }
      
      // Allows user to read and write their own notifications
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
      
      // Allows user to read and write their own conversations
      match /conversations/{taskId} {
        allow read, write: if isOwner(userId);
      }
      
      // Fallback recursive wildcard to securely allow access to any future nested collections
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
